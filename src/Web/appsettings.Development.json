{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore.SpaProxy": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AppSettings": {
    // Local operators point at loopback or a LAN emulator; deployed environments reject those.
    "AllowPrivateCredentialHosts": true
  }
}
