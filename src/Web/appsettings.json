{
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost;user id=postgres;password=super;database=TrackHub;port=5432",
    "Logging": "server=localhost;user id=postgres;password=super;database=TrackHub;port=5432"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.PostgreSQL.Configuration"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "PostgreSQL",
        "Args": {
          "connectionString": "Logging",
          "tableName": "logs",
          "needAutoCreateTable": true,
          "batchSizeLimit": 50,
          "period": "00:00:02"
        }
      }
    ]
  },
  "Columns": {
    "message": "RenderedMessageColumnWriter",
    "message_template": "MessageTemplateColumnWriter",
    "level": {
      "Name": "LevelColumnWriter",
      "Args": {
        "renderAsText": true,
        "dbType": "Varchar"
      }
    },
    "raise_date": "TimestampColumnWriter",
    "exception": "ExceptionColumnWriter",
    "properties": "LogEventSerializedColumnWriter",
    "machine_name": {
      "Name": "SinglePropertyColumnWriter",
      "Args": {
        "propertyName": "MachineName",
        "writeMethod": "Raw"
      }
    },
    "application": {
      "Name": "SinglePropertyColumnWriter",
      "Args": {
        "propertyName": "Application",
        "writeMethod": "Raw"
      }
    },
    "environment_name": {
      "Name": "SinglePropertyColumnWriter",
      "Args": {
        "propertyName": "EnvironmentName",
        "writeMethod": "Raw"
      }
    }
  },
  "AuthorityServer": {
    "Authority": "https://localhost/Identity",
    "ValidateAudience": true,
    "ValidAudience": "trackhub_api",
    "ValidateIssuer": true,
    "ValidateIssuerSigningKey": true
  },
  "AppSettings": {
    "GraphQLIdentityService": "https://localhost/Security/graphql/",
    "GraphQLSecurityService": "https://localhost/Security/graphql/",
    "GraphQLRouterService": "https://localhost/Router/graphql/",
    "EncryptionKey": "4F2C2E66-107F-452A-ACDE-402DFD47B84C",
    // Notifications (spec 05). Portal link embedded in channel messages.
    "PortalBaseUrl": "https://localhost:3000",
    // Sent/Failed/Digested delivery rows older than this are purged daily.
    "NotificationDeliveryRetentionDays": 90,
    // Email channel (spec 05 §14): dev points at a local capture container (e.g. smtp4dev on 2525);
    // production overrides via environment variables (SVD-02 pattern). Empty Host disables sends.
    "Smtp": {
      "Host": "",
      "Port": 25,
      "Username": "",
      "Password": "",
      "UseStartTls": false,
      "FromAddress": "alerts@trackhub.local",
      "FromName": "TrackHub Alerts"
    },
    // WhatsApp channel (spec 05 §14): Meta Cloud API, outbound utility templates only. Empty
    // PhoneNumberId/AccessToken disables sends (external blocker: verified Meta Business + WABA).
    "WhatsApp": {
      "ApiBaseUrl": "https://graph.facebook.com/v21.0",
      "PhoneNumberId": "",
      "AccessToken": "",
      "TemplateName": "trackhub_alert"
    }
  },
  "OpenIddict": {
    "LoadCertFromFile": true,
    "Path": "C:\\Certificates\\certificate.pfx",
    "Password": "openiddict",
    "Thumbprint": "33c9717a58f5f1c56f52d6de066098d5010dd673"
  },
  "AllowedHosts": "*",
  "AllowedCorsOrigins": "https://localhost:3000",
  // Document byte storage (spec 04). Provider selects the IDocumentStorage implementation.
  //   "LocalFileSystem" (default) - LocalRootPath must be a WRITABLE directory (the app dir is read-only under IIS).
  //   "S3"                        - AWS S3 or any S3-compatible service (MinIO); set the S3 section.
  //   "AzureBlob"                 - Azure Blob Storage; set the AzureBlob section.
  "DocumentStorage": {
    "Provider": "LocalFileSystem",
    // Empty -> a writable OS-temp folder (dev). For production set a durable WRITABLE path the app can
    // write to, e.g. "C:\\TrackHubData\\Documents" (create it and grant the app pool identity write access).
    "LocalRootPath": "",
    "RetentionDays": 1825,
    "S3": {
      "BucketName": "",
      "Region": "us-east-1",
      "ServiceUrl": "",
      "ForcePathStyle": false,
      "AccessKey": "",
      "SecretKey": "",
      "PresignedExpiryMinutes": 5
    },
    "AzureBlob": {
      "ConnectionString": "",
      "ContainerName": "documents",
      "SasExpiryMinutes": 5
    }
  }
}
